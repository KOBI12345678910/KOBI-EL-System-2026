# ═══════════════════════════════════════════════════════════════════════════
# ERP 2026 — KOBI EL  .env.example
# Copy to .env and fill in the values:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ─── Global ────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_dev_password
POSTGRES_DB=erp_main
POSTGRES_PORT=5432

# Convenience DSN (used by services)
DATABASE_URL=postgres://erp:erp_dev_password@postgres:5432/erp_main

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ─── Supabase (local-dev fallbacks; onyx-procurement validates these) ─────
SUPABASE_URL=http://postgres:5432
SUPABASE_ANON_KEY=local-dev-anon-key
SUPABASE_SERVICE_KEY=local-dev-service-key

# ─── Security / Auth ───────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-me
SESSION_SECRET=dev-session-secret-change-me
API_KEY_ADMIN=dev-admin-api-key
AUTH_MODE=api_key

# ─── Onyx Procurement ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
SENTRY_DSN=

# ─── Techno-Kol Ops ────────────────────────────────────────────────────────
OPS_REALTIME_ENABLED=true
OPS_WEBSOCKET_PATH=/ws

# ─── Onyx AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ONYX_GOVERNOR_ENABLED=true

# ─── Payroll Autonomous ───────────────────────────────────────────────────
PAYROLL_HOST=localhost
VITE_API_URL=http://localhost:3100

# ─── Reverse proxy (profile: proxy) ───────────────────────────────────────
PROXY_PORT=80

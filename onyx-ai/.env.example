# ═══════════════════════════════════════════════════════════
# ONYX AI v2.0 — Environment Configuration Example
# Copy this file to `.env` and fill in the real values.
# NEVER commit the actual .env file.
# ═══════════════════════════════════════════════════════════

# ─── Core ───
NODE_ENV=development
# B-22: onyx-ai uses port 3200 to avoid collision with onyx-procurement (3100)
PORT=3200
LOG_LEVEL=info

# ─── Governance ───
ONYX_GLOBAL_BUDGET=1000
ONYX_DAILY_BUDGET=500

# ─── Credential Vault (AES-256-CBC master key, 32 bytes hex) ───
ONYX_VAULT_KEY=

# ─── AI / LLM providers ───
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# ─── Messaging ───
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ─── Google (Gmail / Calendar / Drive) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:3100/oauth/callback

# ─── SendGrid ───
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ─── Database ───
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── CRM / Payments ───
HUBSPOT_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Automation ───
N8N_WEBHOOK_URL=
MAKE_WEBHOOK_URL=

# ─── Monitoring ───
DISCORD_WEBHOOK_URL=
HEALTH_CHECK_TARGETS=

# ─── Event Store ───
ONYX_EVENT_STORE_PATH=./data/events.jsonl
ONYX_KNOWLEDGE_GRAPH_PATH=./data/graph.json

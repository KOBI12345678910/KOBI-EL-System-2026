# ═══════════════════════════════════════════
# TECHNO-KOL OPS — Environment
# Wave 1.5 — 360° compliance hardening
# ═══════════════════════════════════════════

# ─── Server ───
PORT=5000
NODE_ENV=development
# B-24: APP_URL required for CORS, email links, receipt URLs
APP_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173,http://localhost:3100

# ─── Database ───
DATABASE_URL=postgresql://user:password@localhost:5432/techno_kol

# ─── Auth ───
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32_OUTPUT
JWT_EXPIRES_IN=24h

# ─── Integration with ONYX ecosystem ───
ONYX_PROCUREMENT_URL=http://localhost:3100
ONYX_AI_URL=http://localhost:3200
ONYX_PROCUREMENT_API_KEY=

# ─── Logging ───
LOG_LEVEL=info

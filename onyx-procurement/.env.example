# ════════════════════════════════════════════════════════════════════════════
#  ONYX PROCUREMENT SYSTEM — .env.example
#  Wave 1.5 — 360° compliance hardening  |  Agent-47 upgrade
#
#  HOW TO USE:
#     cp .env.example .env              # on Linux/macOS
#     copy .env.example .env            # on Windows
#     node scripts/validate-env.js      # verifies everything below is sane
#
#  LEGEND:
#     [REQUIRED] server will refuse to start without this
#     [SECRET]   never commit the real value; rotate regularly
#     [OPTIONAL] safe default is used when unset
# ════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
#  SERVER RUNTIME
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] TCP port the Express server binds to.
#   default: 3100   valid: 1..65535
#   example: PORT=3100
PORT=3100

# [REQUIRED] Runtime mode. Controls error verbosity, cookie flags, log format.
#   enum: development | production | test | staging
#   example: NODE_ENV=development
NODE_ENV=development

# [OPTIONAL] Comma-separated CORS origins. Use "*" only in pure dev.
#   example: ALLOWED_ORIGINS=https://ops.example.co.il,https://admin.example.co.il
ALLOWED_ORIGINS=http://localhost:3100,http://localhost:5173

# [OPTIONAL] Public base URL of this app (used in emails, QR links, OAuth callbacks).
#   example: APP_URL=https://onyx.example.co.il
APP_URL=http://localhost:3100


# ─────────────────────────────────────────────────────────────────────────────
#  AUTHENTICATION   (B-03 hardening)
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Auth strategy.
#   enum: api_key | jwt | disabled
#   WARNING: "disabled" is dev-only. Production will be rejected by validator.
AUTH_MODE=api_key

# [SECRET] Comma-separated API keys (hex, 32+ chars each).
#   generate: openssl rand -hex 32
#   example: API_KEYS=a3f2...b7,4c1e...9d
API_KEYS=

# [SECRET] Single API key — used by scripts that only need one.
#   generate: openssl rand -hex 32
API_KEY=

# [SECRET] JWT signing secret. Minimum 32 random bytes (base64 or hex).
#   generate: openssl rand -base64 48
JWT_SECRET=

# [SECRET] HMAC shared secret for inbound webhook verification. 16+ bytes.
#   generate: openssl rand -hex 32
WEBHOOK_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
#  RATE LIMITS   (B-17)
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Max API requests per 15-minute window, per IP.
#   default: 300
RATE_LIMIT_API_MAX=300

# [OPTIONAL] Max inbound webhook requests per 15-minute window.
#   default: 120
RATE_LIMIT_WEBHOOK_MAX=120


# ─────────────────────────────────────────────────────────────────────────────
#  TAX / VAT   (B-05)
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Israel VAT rate as decimal.  0.17 = 17% (2026 default).
#   example: VAT_RATE=0.17
VAT_RATE=0.17

# [OPTIONAL] Company VAT file number assigned by the Israel Tax Authority.
ISRAEL_TAX_VAT_FILE_NUMBER=

# [OPTIONAL] 9-digit company / Osek Morshe ID.
ISRAEL_TAX_COMPANY_ID=


# ─────────────────────────────────────────────────────────────────────────────
#  SUPABASE
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Supabase project REST URL.
#   example: SUPABASE_URL=https://abcd1234.supabase.co
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# [REQUIRED] Anon (public) key — browser-safe, RLS enforced.
#   Find under: Project Settings -> API -> anon public
SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY

# [SECRET] Service role key — BYPASSES RLS. Server-side ONLY.
#   Find under: Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY

# [SECRET] Alias used by legacy scripts/seed-data.js and older code paths.
#   You can mirror the same value as SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_KEY=

# [OPTIONAL] Direct Postgres connection string for scripts/migrate-verify.js
#   example: SUPABASE_DB_URL=postgresql://postgres:PASS@db.abcd.supabase.co:5432/postgres
SUPABASE_DB_URL=

# [OPTIONAL] Comma-separated whitelist of tables for scripts/backup.js.
#   empty = dump every table in the `public` schema
SUPABASE_BACKUP_TABLES=


# ─────────────────────────────────────────────────────────────────────────────
#  WHATSAPP BUSINESS API (Meta)
# ─────────────────────────────────────────────────────────────────────────────

# [SECRET] Graph API bearer token for outbound messages.
WHATSAPP_TOKEN=YOUR_WHATSAPP_TOKEN

# [OPTIONAL] WhatsApp Business phone-number ID used as sender.
WHATSAPP_PHONE_ID=YOUR_PHONE_ID

# [SECRET] Static token Meta echoes back during webhook subscription handshake.
#   Pick any strong random string you also paste into Meta dashboard.
WHATSAPP_VERIFY_TOKEN=onyx_verify_2026

# [SECRET] Meta App Secret used to HMAC-verify WhatsApp webhook signatures (B-04).
#   REQUIRED in production.
WHATSAPP_APP_SECRET=YOUR_META_APP_SECRET


# ─────────────────────────────────────────────────────────────────────────────
#  TWILIO SMS   (optional fallback channel)
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Twilio Account SID (starts with AC...).
# TWILIO_SID=

# [SECRET] Twilio auth token — rotate quarterly.
# TWILIO_AUTH_TOKEN=

# [OPTIONAL] Sender number in E.164 format.
#   example: TWILIO_FROM=+15551234567
# TWILIO_FROM=


# ─────────────────────────────────────────────────────────────────────────────
#  LOGGING
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Pino log level threshold.
#   enum: trace | debug | info | warn | error | fatal | silent
#   default: info
LOG_LEVEL=info

# [OPTIONAL] Output format. "json" for prod, "pretty" for local.
#   enum: json | pretty
#   default: json
LOG_FORMAT=json


# ─────────────────────────────────────────────────────────────────────────────
#  FILE SYSTEM PATHS
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Directory where generated payroll PDFs are written.
#   default: ./data/payroll/pdf
PAYROLL_PDF_DIR=./data/payroll/pdf

# [OPTIONAL] Output directory for scripts/backup.js dumps.
#   default: ./backups
BACKUP_DIR=./backups

# [OPTIONAL] Archive directory for PCN836 VAT submission XML files.
#   default: ./data/pcn836
PCN836_ARCHIVE_DIR=./data/pcn836


# ─────────────────────────────────────────────────────────────────────────────
#  OBSERVABILITY   (Sentry / error-tracker)
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Sentry DSN. If unset, error-tracker runs in local-only mode.
#   example: SENTRY_DSN=https://PUBLIC_KEY@oXXXX.ingest.sentry.io/PROJECT_ID
SENTRY_DSN=

# [OPTIONAL] Release tag (falls back to `onyx@<pkg.version>`).
#   example: RELEASE=onyx@1.1.0-staging
RELEASE=


# ─────────────────────────────────────────────────────────────────────────────
#  OPS / ALERTING   (notification-dispatcher)
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Enabled alert channels.
#   example: NOTIFY_CHANNELS=file,email,whatsapp
NOTIFY_CHANNELS=

# [OPTIONAL] Path to the alerts log file.
#   default: ops/alerts/alerts.log
NOTIFY_FILE_PATH=

# [OPTIONAL] Email recipient for ops alerts.
#   example: NOTIFY_EMAIL_TO=oncall@example.co.il
NOTIFY_EMAIL_TO=

# [OPTIONAL] WhatsApp recipient phone (E.164).
#   example: NOTIFY_WHATSAPP_TO=+972501234567
NOTIFY_WHATSAPP_TO=

# [OPTIONAL] SMS fallback recipient phone (E.164).
#   example: NOTIFY_SMS_TO=+972501234567
NOTIFY_SMS_TO=


# ─────────────────────────────────────────────────────────────────────────────
#  ONYX AI BRIDGE
# ─────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Base URL of the Onyx AI service.
#   default: http://localhost:3200
ONYX_AI_URL=

# [SECRET] Shared secret sent as X-API-Key to Onyx AI. Empty = bridge disabled.
#   generate: openssl rand -hex 32
ONYX_AI_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  LOAD TEST HARNESS   (test/load/api-load.js — never used in prod)
# ─────────────────────────────────────────────────────────────────────────────

# LOAD_TEST_BASE_URL=http://localhost:3100
# LOAD_TEST_API_KEY=dev-key
# LOAD_TEST_TIMEOUT_MS=10000
# LOAD_TEST_ONLY=health,rate-limit

# TechnoKol Uzi ERP System - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/techno-kol-uzi

# ===== API SERVER =====
PORT=8080
NODE_ENV=development
API_URL=http://localhost:8080
VITE_API_URL=http://localhost:8080
SESSION_SECRET=your-secret-key-here-change-in-production

# ===== FRONTEND =====
VITE_BASE_URL=/
BASE_PATH=/
HMR_HOST=localhost
HMR_PORT=443

# ===== AUTHENTICATION =====
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SESSION_DURATION_HOURS=0.5

# ===== MFA & SECURITY =====
MFA_ENABLED=true
TOTP_ISSUER=TechnoKol ERP
IP_ALLOWLIST_ENABLED=false
IP_WHITELIST=

# ===== RATE LIMITING =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
LOGIN_RATE_LIMIT=10/15min
SEARCH_RATE_LIMIT=100/min

# ===== EMAIL CONFIGURATION =====
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
SENDER_EMAIL=noreply@techno-kol-uzi.co.il

# ===== WHATSAPP BUSINESS API =====
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-account-id
WHATSAPP_BUSINESS_PHONE_ID=your-phone-id
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-token
WHATSAPP_BUSINESS_WEBHOOK_TOKEN=your-webhook-token

# ===== BACKUP CONFIGURATION =====
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=6
BACKUP_STORAGE_PATH=./backups

# ===== SERVER HEALTH MONITORING =====
HEALTH_MONITOR_INTERVAL_MS=30000
HEALTH_CHECK_TIMEOUT_MS=5000
HEALTH_CHECK_CPU_THRESHOLD=90
HEALTH_CHECK_MEMORY_THRESHOLD=85
HEALTH_CHECK_DISK_THRESHOLD=90

# ===== GOOGLE DRIVE / CLOUD STORAGE =====
GOOGLE_DRIVE_API_KEY=your-google-drive-api-key
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# ===== SLACK NOTIFICATIONS =====
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_ENABLED=false

# ===== SENTRY ERROR TRACKING =====
SENTRY_DSN=your-sentry-dsn-optional
SENTRY_ENVIRONMENT=development

# ===== FEATURE FLAGS =====
FEATURE_INVENTORY_MANAGEMENT=true
FEATURE_WORK_ORDERS=true
FEATURE_CUSTOMERS_FINANCE=true
FEATURE_REPORTS_DASHBOARDS=true
FEATURE_ALERTS_NOTIFICATIONS=true

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== PRODUCTION FLAGS =====
PRODUCTION_MODE=false
ALLOW_DEMO_RESET=false
MAINTENANCE_MODE=false
